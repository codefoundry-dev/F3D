# Dependencies
node_modules
.pnp
.pnp.js

# Build outputs
dist
build
out
.next
.expo
.turbo

# shared-types: dist/*.js is mirrored into src/ at build time so the
# @nestjs/swagger plugin's relative require()s resolve at runtime. Treat the
# generated siblings as build artefacts.
packages/shared-types/src/**/*.js
packages/shared-types/src/**/*.js.map

# Environment variables (NEVER commit these)
.env
.env.*
!.env.example
!.env.*.example

# MCP config (contains API tokens)
.mcp.json

# Coverage reports
coverage
*.lcov
.nyc_output

# Logs
*.log
logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE / Editor
.vscode
.idea
*.swp
*.swo
*.swn
*~

# TypeScript incremental compilation
*.tsbuildinfo

# Prisma
prisma/migrations/.migration_lock

# Testing
# Jest unit snapshots are committed (CI fails on a missing snapshot instead of
# writing one); only Playwright report/artifact output is ignored.
playwright-report
test-results

# Claude Code
.claude/settings.local.json
# Throwaway git worktrees created by the Agent tool (isolation: worktree)
.claude/worktrees/

# Misc
.cache
.prettiercache
tmp/
temp/
*.timestamp-*.mjs
