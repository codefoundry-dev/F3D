# Cross-platform line-ending discipline.
#
# Goal: prevent cross-platform hash drift on files that terraform renders /
# hashes (templatefile -> SHA1 -> aws_instance.user_data), files that run on
# Linux servers, and files that other tools parse on the runner side.
#
# Without this, a Windows checkout (autocrlf=true) and a Linux GH Actions
# checkout produce different file bytes for the same commit, terraform sees
# the user_data hash flip, and an apply churns the EC2 instance.

# Default: let git auto-detect, but normalize stored line endings to LF.
* text=auto eol=lf

# Files that are LF-only on every platform.
*.sh        text eol=lf
*.tftpl     text eol=lf
*.tf        text eol=lf
*.hcl       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.json      text eol=lf
*.md        text eol=lf
Dockerfile  text eol=lf
.dockerignore text eol=lf
Caddyfile*  text eol=lf

# Files that MUST stay CRLF (Windows-only).
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

# Binary - never touch these.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.webp binary
*.pdf  binary
*.zip  binary
*.gz   binary
*.tgz  binary
*.tar  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.otf  binary
*.eot  binary
