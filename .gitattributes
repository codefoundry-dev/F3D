# Force LF line endings in the working tree for all text files, overriding a
# local core.autocrlf=true. On Windows, CRLF was being baked into the Terraform
# user_data template (modules/compute-ec2/user_data.sh.tftpl); that differs from
# CI's LF render, and with user_data_replace_on_change=true it silently
# force-replaced the staging EC2 on every local `terraform apply`.
* text=auto eol=lf

# Binary types: leave bytes untouched.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.pdf  binary
*.woff  binary
*.woff2 binary
*.ttf  binary
*.eot  binary
