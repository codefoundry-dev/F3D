# =============================================================================
# Forethread Super Admin App — Environment Variables
# Copy to .env and fill in values before running the application.
# Vite requires VITE_ prefix for variables exposed to the browser.
# =============================================================================

# ─── API ──────────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3000/v1

# ─── Observability ────────────────────────────────────────────────────────────
# Leave empty for local development
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development
