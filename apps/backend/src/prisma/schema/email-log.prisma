/// Rolled-up delivery status of a single outbound email (FOR-213). Derived from
/// the EmailEvent stream — see EmailLogService for the precedence rules that keep
/// late / out-of-order webhooks from downgrading a more advanced status.
enum EmailDeliveryStatus {
  QUEUED
  SENT
  DELIVERED
  DELIVERY_DELAYED
  OPENED
  CLICKED
  BOUNCED
  COMPLAINED
  FAILED
}

/// A single Resend webhook event type recorded against an outbound email (FOR-213).
enum EmailEventType {
  SENT
  DELIVERED
  DELIVERY_DELAYED
  OPENED
  CLICKED
  BOUNCED
  COMPLAINED
  FAILED
}

/// One outbound transactional email we sent (FOR-213). Linked to the RFQ or PO it
/// concerns so the contractor can see send status, opens, and bounces on the
/// detail page. Resend delivery events stream in via webhooks into EmailEvent and
/// roll up into the denormalised status / timestamp columns here.
model EmailMessage {
  id                String              @id @default(uuid())
  companyId         String              @map("company_id")
  rfqId             String?             @map("rfq_id")
  purchaseOrderId   String?             @map("purchase_order_id")
  template          String              @db.VarChar(100)
  toEmail           String              @map("to_email") @db.VarChar(320)
  subject           String              @db.VarChar(500)
  provider          String              @default("RESEND") @db.VarChar(20)
  // Resend's message id (response.data.id). Null for the SMTP fallback, which has
  // no webhooks. Postgres treats NULLs as distinct, so the SMTP rows don't clash.
  providerMessageId String?             @unique @map("provider_message_id") @db.VarChar(255)
  status            EmailDeliveryStatus @default(QUEUED)
  // The contractor user who triggered the send (best-effort, scalar — not an FK).
  sentByUserId      String?             @map("sent_by_user_id")
  sentAt            DateTime?           @map("sent_at")
  deliveredAt       DateTime?           @map("delivered_at")
  openedAt          DateTime?           @map("opened_at")
  bouncedAt         DateTime?           @map("bounced_at")
  complainedAt      DateTime?           @map("complained_at")
  openCount         Int                 @default(0) @map("open_count")
  bounceType        String?             @map("bounce_type") @db.VarChar(100)
  bounceReason      String?             @map("bounce_reason")
  lastEventAt       DateTime?           @map("last_event_at")
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")

  rfq           Rfq?           @relation("RfqEmailMessages", fields: [rfqId], references: [id], onDelete: Cascade)
  purchaseOrder PurchaseOrder? @relation("PoEmailMessages", fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  events        EmailEvent[]

  @@index([rfqId], map: "idx_email_messages_rfq")
  @@index([purchaseOrderId], map: "idx_email_messages_po")
  @@index([companyId], map: "idx_email_messages_company")
  @@map("email_messages")
}

/// A single delivery event for an EmailMessage (FOR-213), captured from a Resend
/// webhook (sent / delivered / opened / bounced / complained / …). The raw
/// provider payload is retained for debugging and audit. The (message, type,
/// occurredAt) unique key makes webhook re-delivery idempotent.
model EmailEvent {
  id              String         @id @default(uuid())
  emailMessageId  String         @map("email_message_id")
  type            EmailEventType
  occurredAt      DateTime       @map("occurred_at")
  // Svix message id (svix-id header) when present — for traceability.
  providerEventId String?        @map("provider_event_id") @db.VarChar(255)
  payload         Json?
  createdAt       DateTime       @default(now()) @map("created_at")

  emailMessage EmailMessage @relation(fields: [emailMessageId], references: [id], onDelete: Cascade)

  @@unique([emailMessageId, type, occurredAt], map: "uq_email_events_dedupe")
  @@index([emailMessageId], map: "idx_email_events_message")
  @@map("email_events")
}
