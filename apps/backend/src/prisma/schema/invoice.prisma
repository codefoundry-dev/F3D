enum InvoiceStatus {
  PENDING
  APPROVED
  DISPUTED
  PAID
  REJECTED
}

model Invoice {
  id              String        @id @default(uuid())
  projectId       String        @map("project_id")
  companyId       String        @map("company_id")
  vendorId        String        @map("vendor_id")
  relatedPoId     String?       @map("related_po_id")
  status          InvoiceStatus @default(PENDING)
  totalAmount     Decimal       @map("total_amount") @db.Decimal(18, 4)
  dueDate         DateTime?     @map("due_date")
  createdByUserId String        @map("created_by_user_id")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  project   Project        @relation(fields: [projectId], references: [id])
  company   Company        @relation("InvoiceCompany", fields: [companyId], references: [id])
  vendor    Company        @relation("InvoiceVendor", fields: [vendorId], references: [id])
  relatedPo PurchaseOrder? @relation("InvoiceRelatedPo", fields: [relatedPoId], references: [id])
  createdBy User           @relation("InvoiceCreatedBy", fields: [createdByUserId], references: [id])
  documents InvoiceDocument[]

  @@index([companyId], map: "idx_invoices_company")
  @@index([projectId], map: "idx_invoices_project")
  @@index([vendorId], map: "idx_invoices_vendor")
  @@index([status], map: "idx_invoices_status")
  @@map("invoices")
}

model InvoiceDocument {
  id        String   @id @default(uuid())
  invoiceId String   @map("invoice_id")
  fileId    String   @map("file_id")
  createdAt DateTime @default(now()) @map("created_at")

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  file    File    @relation(fields: [fileId], references: [id])

  @@index([invoiceId], map: "idx_invoice_documents_invoice")
  @@map("invoice_documents")
}
