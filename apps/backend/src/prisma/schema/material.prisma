enum MaterialStatus {
  PUBLIC
  PENDING_APPROVAL
  ARCHIVED
}

enum MaterialChangeRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model MaterialCategory {
  id        String   @id @default(uuid())
  name      String   @unique @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")

  materials Material[]

  @@map("material_categories")
}

model Material {
  id                     String         @id @default(uuid())
  name                   String         @db.VarChar(255)
  // Case-insensitive alphabetical sort key. A Postgres STORED generated column
  // (lower(name)), maintained automatically by the DB — the app never writes it
  // (it is omitted from every insert/update). Ordering by `name` used the
  // column's case-sensitive default collation, so a mixed-case bulk-imported
  // catalogue sorted uppercase-before-lowercase and looked non-alphabetical.
  // See migration 20260609100000_materials_name_ci_sort. NOTE: hand-written
  // migration — do not `prisma migrate dev` (it would recreate this as a plain
  // column). It is optional only so it is never required on create.
  nameCi                 String?        @map("name_ci")
  categoryId             String         @map("category_id")
  uom                    String         @db.VarChar(50)
  upc                    String?        @db.VarChar(100)
  manufacturer           String?        @db.VarChar(255)
  description            String?
  sku                    String?        @unique(map: "idx_material_sku") @db.VarChar(100)
  brand                  String?        @db.VarChar(255)
  manufacturerPartNumber String?        @map("manufacturer_part_number") @db.VarChar(255)
  subCategory            String?        @map("sub_category") @db.VarChar(255)
  imageUrl               String?        @map("image_url")
  // ── Rich catalogue attributes (US 4.01) ──────────────────────────────────
  materialType             String?  @map("material_type") @db.VarChar(100)
  itemType                 String?  @map("item_type") @db.VarChar(100)
  countryOfOrigin          String?  @map("country_of_origin") @db.VarChar(100)
  manufacturerSeriesModel  String?  @map("manufacturer_series_model") @db.VarChar(255)
  gradeClass               String?  @map("grade_class") @db.VarChar(100)
  standardNorm             String?  @map("standard_norm") @db.VarChar(100)
  colourFinish             String?  @map("colour_finish") @db.VarChar(100)
  size                     String?  @db.VarChar(100)
  pricePerUnit             Decimal? @map("price_per_unit") @db.Decimal(18, 4)
  currency                 String   @default("AUD") @db.VarChar(3)
  // {length:{value,uom}, width:{...}, ..., packaging:{packagingUnit, unitsPerPackage, weightPerPackage}}
  dimensions               Json?
  // Open-ended, category-specific "Specific data".
  properties               Json?
  status                 MaterialStatus @default(PENDING_APPROVAL)
  // Owning company for a company-private material (US 4.02). NULL ⇒ a PUBLIC,
  // shared catalogue row (Super-Admin or approved). A non-null company_id scopes
  // visibility to that company until the row is approved (promoted to PUBLIC,
  // company_id → NULL). Existing rows default to NULL (public), no backfill.
  companyId              String?        @map("company_id")
  createdById            String         @map("created_by_id")
  createdAt              DateTime       @default(now()) @map("created_at")
  updatedAt              DateTime       @updatedAt @map("updated_at")

  category     MaterialCategory @relation(fields: [categoryId], references: [id])
  createdBy    User             @relation("MaterialCreatedBy", fields: [createdById], references: [id])
  company      Company?         @relation("MaterialCompany", fields: [companyId], references: [id])

  poLineItems          PoLineItem[]
  rfqLineItems         RfqLineItem[]
  materialRequestLineItems MaterialRequestLineItem[]
  quoteSubstituteItems QuoteResponseLineItem[] @relation("QuoteSubstituteItem")
  bomItems             BomItem[]               @relation("BomItemMatchedMaterial")
  materialListItems    MaterialListItem[]
  changeRequests       MaterialChangeRequest[]
  favourites           MaterialFavourite[]

  @@index([categoryId], map: "idx_materials_category")
  @@index([status], map: "idx_materials_status")
  @@index([name], map: "idx_materials_name")
  @@index([nameCi], map: "idx_materials_name_ci")
  @@index([materialType], map: "idx_materials_material_type")
  @@index([itemType], map: "idx_materials_item_type")
  @@index([companyId], map: "idx_materials_company")
  @@map("materials")
}

/// A proposed edit to a PUBLIC catalogue material (US 4.01 Phase 3). A
/// Company-Admin / Procurement-Officer edit is captured here as a PENDING diff
/// instead of mutating the live material; the catalogue Super-Admin approves
/// (applies `changedFields` to the material) or rejects (discards). Mirrors
/// PoChangeRequest / BulkOrderChangeRequest.
model MaterialChangeRequest {
  id            String                      @id @default(uuid())
  materialId    String                      @map("material_id")
  // { field: { from, to } } before/after diff, rendered as the edit-diff card.
  changedFields Json                        @map("changed_fields")
  status        MaterialChangeRequestStatus @default(PENDING)
  reason        String?
  requestedById String                      @map("requested_by_id")
  resolvedById  String?                     @map("resolved_by_id")
  resolvedAt    DateTime?                   @map("resolved_at")
  createdAt     DateTime                    @default(now()) @map("created_at")

  material    Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
  requestedBy User     @relation("MaterialChangeRequestedBy", fields: [requestedById], references: [id])
  resolvedBy  User?    @relation("MaterialChangeResolvedBy", fields: [resolvedById], references: [id])

  @@index([materialId], map: "idx_material_change_requests_material")
  @@index([status], map: "idx_material_change_requests_status")
  @@map("material_change_requests")
}

/// A reusable, company-scoped collection of catalogue materials (US 5.05).
/// Buyers pick a saved list during RFQ creation to pre-fill line items.
model MaterialList {
  id          String   @id @default(uuid())
  name        String   @db.VarChar(255)
  description String?
  companyId   String   @map("company_id")
  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  company   Company            @relation("MaterialListCompany", fields: [companyId], references: [id])
  createdBy User               @relation("MaterialListCreatedBy", fields: [createdById], references: [id])
  items     MaterialListItem[]

  @@index([companyId], map: "idx_material_lists_company")
  @@map("material_lists")
}

model MaterialListItem {
  id         String   @id @default(uuid())
  listId     String   @map("list_id")
  materialId String   @map("material_id")
  quantity   Int      @default(1)
  createdAt  DateTime @default(now()) @map("created_at")

  list     MaterialList @relation(fields: [listId], references: [id], onDelete: Cascade)
  material Material     @relation(fields: [materialId], references: [id])

  @@unique([listId, materialId], map: "idx_material_list_items_list_material")
  @@map("material_list_items")
}

/// A per-user "saved" / favourite flag on a catalogue material (US 4.03). The
/// composite (user_id, material_id) unique makes favouriting idempotent — adding
/// an existing favourite is a no-op upsert; removing one is a no-op delete.
model MaterialFavourite {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  materialId String   @map("material_id")
  createdAt  DateTime @default(now()) @map("created_at")

  user     User     @relation("MaterialFavouriteUser", fields: [userId], references: [id], onDelete: Cascade)
  material Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@unique([userId, materialId], map: "idx_material_favourites_user_material")
  @@index([materialId], map: "idx_material_favourites_material")
  @@map("material_favourites")
}
