enum DocExtractionStatus {
  PENDING
  PROCESSING
  COMPLETED
  CONFIRMED
  FAILED
}

enum DocExtractionType {
  BOM
  QUOTE
  INVOICE
  GENERIC
}

model DocExtraction {
  id                  String              @id @default(uuid())
  type                DocExtractionType
  status              DocExtractionStatus @default(PENDING)
  fileId              String              @map("file_id")
  rawResult           Json?               @map("raw_result")
  editedResult        Json?               @map("edited_result")
  errorCode           String?             @map("error_code") @db.VarChar(64)
  errorMessage        String?             @map("error_message")
  model               String?             @db.VarChar(100)
  promptTokens        Int?                @map("prompt_tokens")
  completionTokens    Int?                @map("completion_tokens")
  createdByUserId     String              @map("created_by_user_id")
  lastEditedByUserId  String?             @map("last_edited_by_user_id")
  lastEditedAt        DateTime?           @map("last_edited_at")
  confirmedByUserId   String?             @map("confirmed_by_user_id")
  companyId           String?             @map("company_id")
  // Set when a guest vendor uploads a quote PDF through the tokenized RFQ portal
  // (FOR-206). Scopes the public, token-less poll endpoint to guest QUOTE jobs
  // and links the extraction back to its RFQ. Plain scalar (no relation) to keep
  // doc-intelligence decoupled from the RFQ module.
  rfqId               String?             @map("rfq_id")
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")
  completedAt         DateTime?           @map("completed_at")
  confirmedAt         DateTime?           @map("confirmed_at")

  file          File     @relation(fields: [fileId], references: [id])
  createdBy     User     @relation("DocExtractionCreatedBy", fields: [createdByUserId], references: [id])
  lastEditedBy  User?    @relation("DocExtractionLastEditedBy", fields: [lastEditedByUserId], references: [id])
  confirmedBy   User?    @relation("DocExtractionConfirmedBy", fields: [confirmedByUserId], references: [id])
  company       Company? @relation("DocExtractionCompany", fields: [companyId], references: [id])

  @@index([createdByUserId], map: "idx_doc_extractions_created_by")
  @@index([companyId, status], map: "idx_doc_extractions_company_status")
  @@index([type, status], map: "idx_doc_extractions_type_status")
  @@index([rfqId], map: "idx_doc_extractions_rfq")
  @@map("doc_extractions")
}
