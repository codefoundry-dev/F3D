enum AccessTokenSubject {
  RFQ
  QUOTE_RESPONSE
  INVOICE
  PURCHASE_ORDER
}

enum AccessTokenPurpose {
  RFQ_VIEW
  QUOTE_SUBMIT
  INVOICE_UPLOAD
  PO_VIEW
  // Epic 6 — Delivery. DELIVERY_SUBMIT is the long-lived (90-day) QR-link token
  // embedded in a PO's delivery QR code; like PO_VIEW it is validated, never
  // consumed, and re-mintable via issueTokenIfNoneLive. DELIVERY_SESSION is a
  // short-lived (30-min) token minted after the delivery person verifies an
  // emailed access code; it authorises submit + uploads and carries the
  // submitter identity ({email,name}) plus, once a report is created, its
  // {deliveryReportId}.
  DELIVERY_SUBMIT
  DELIVERY_SESSION
}

/// Tokenized access grant used by the vendor portal (FOR-201).
///
/// The visible token presented to a client is `${lookupId}_${secret}`:
///   - `lookupId` is a high-entropy public identifier (≥80 bits) used as a
///     direct DB key so validation is O(1) instead of iterating candidate rows.
///   - `secret` is 32 random bytes (256 bits) — well above the ≥128-bit bar.
///     Only its SHA-256 digest is stored, so a DB compromise does not leak the
///     usable token.
///
/// Single-use enforcement: `usedAt` is set during `consume()`; subsequent
/// validations against a consumed token return 403.
///
/// Rate limiting: each validation attempt increments `attempts`. Once
/// `attempts >= maxAttempts` the token is locked out (429) until manual
/// intervention or revocation.
model AccessToken {
  id              String              @id @default(uuid())
  lookupId        String              @unique @map("lookup_id") @db.VarChar(32)
  tokenHash       String              @map("token_hash") @db.VarChar(128)
  subjectType     AccessTokenSubject  @map("subject_type")
  subjectId       String              @map("subject_id")
  purpose         AccessTokenPurpose
  expiresAt       DateTime            @map("expires_at")
  usedAt          DateTime?           @map("used_at")
  attempts        Int                 @default(0)
  maxAttempts     Int                 @default(10) @map("max_attempts")
  lastAttemptIp   String?             @map("last_attempt_ip") @db.VarChar(64)
  lastAttemptAt   DateTime?           @map("last_attempt_at")
  revokedAt       DateTime?           @map("revoked_at")
  createdByUserId String?             @map("created_by_user_id")
  metadata        Json?
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  createdBy User? @relation("AccessTokenCreatedBy", fields: [createdByUserId], references: [id])

  @@index([subjectType, subjectId], map: "idx_access_tokens_subject")
  @@index([expiresAt], map: "idx_access_tokens_expires_at")
  @@map("access_tokens")
}
