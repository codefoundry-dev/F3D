enum ProjectStatus {
  PLANNED
  ONGOING
  COMPLETED
  ARCHIVED
}

enum LocationType {
  DELIVERY
  STORAGE
}

model Project {
  id                 String        @id @default(uuid())
  companyId          String        @map("company_id")
  name               String        @db.VarChar(255)
  description        String?
  type               String?       @db.VarChar(100)
  status             ProjectStatus @default(PLANNED)
  plannedBudget      Decimal?      @map("planned_budget") @db.Decimal(18, 4)
  currency           String        @default("AUD") @db.VarChar(3)
  startDate          DateTime?     @map("start_date") @db.Date
  expectedEndDate    DateTime?     @map("expected_end_date") @db.Date
  pointOfContactId   String?       @map("point_of_contact_id")
  createdByUserId    String        @map("created_by_user_id")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  // Relations
  company        Company           @relation(fields: [companyId], references: [id])
  pointOfContact User?             @relation("ProjectPointOfContact", fields: [pointOfContactId], references: [id])
  createdBy      User              @relation("ProjectCreator", fields: [createdByUserId], references: [id])
  locations      ProjectLocation[]
  members        ProjectMember[]

  // Procurement relations
  rfqs            Rfq[]
  purchaseOrders  PurchaseOrder[]
  bulkOrders      BulkOrder[]
  invoices        Invoice[]
  boms            Bom[]

  @@unique([companyId, name], map: "idx_projects_company_name")
  @@index([companyId], map: "idx_projects_company")
  @@index([companyId, status], map: "idx_projects_company_status")
  @@index([createdByUserId], map: "idx_projects_created_by")
  @@map("projects")
}

model ProjectLocation {
  id        String       @id @default(uuid())
  projectId String       @map("project_id")
  type      LocationType
  address   String
  label     String?      @db.VarChar(255)
  isDefault Boolean      @default(false) @map("is_default")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  purchaseOrders PurchaseOrder[] @relation("PoDeliveryLocation")
  poLineItems    PoLineItem[]    @relation("PoLineItemDeliveryLocation")
  poDeliveries   PoDelivery[]    @relation("PoDeliveryRowLocation")
  rfqs           Rfq[]           @relation("RfqDeliveryLocation")

  @@index([projectId], map: "idx_projectlocation_project")
  @@index([projectId, type], map: "idx_projectlocation_project_type")
  @@map("project_locations")
}

model ProjectMember {
  id               String   @id @default(uuid())
  projectId        String   @map("project_id")
  userId           String   @map("user_id")
  assignedAt       DateTime @default(now()) @map("assigned_at")
  assignedByUserId String?  @map("assigned_by_user_id")

  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user       User    @relation("ProjectMemberUser", fields: [userId], references: [id])
  assignedBy User?   @relation("ProjectMemberAssignedBy", fields: [assignedByUserId], references: [id])

  @@unique([projectId, userId], map: "idx_projectmember_project_user")
  @@index([projectId], map: "idx_projectmember_project")
  @@index([userId], map: "idx_projectmember_user")
  @@map("project_members")
}
