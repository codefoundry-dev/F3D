{
  "extends": "../../packages/config/tsconfig.node.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@forethread/i18n/locales/*": ["../../packages/i18n/src/locales/*"]
