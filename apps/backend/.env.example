# =============================================================================
# Forethread Backend — Environment Variables
# Copy to .env and fill in all required values before running the application.
# =============================================================================

# ─── Application ──────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3001

# ─── Frontend App URL ─────────────────────────────────────────────────────────
# Used to build email links (reset password, invitation, view RFQ/PO/etc.)
WEB_APP_URL=http://localhost:5179

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://forethread:forethread@localhost:5432/forethread_dev
# Connection pool (optional — Prisma defaults shown)
DATABASE_CONNECTION_LIMIT=10
DATABASE_POOL_TIMEOUT=10

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT Authentication ───────────────────────────────────────────────────────
# Minimum 32 characters for security — use: openssl rand -hex 32
JWT_ACCESS_SECRET=your-local-dev-access-secret-min-32-chars-replace-this
JWT_REFRESH_SECRET=your-local-dev-refresh-secret-min-32-chars-replace-this
JWT_ACCESS_EXPIRES_IN=4h
JWT_REFRESH_EXPIRES_IN=7d

# ─── Email / Resend (preferred transport) ────────────────────────────────────
# Resend is the preferred transport. When RESEND_API_KEY is set, ALL outbound
# email is sent via Resend and the SMTP settings below are ignored. Get an API
# key and verify a sender domain at https://resend.com
# Leave RESEND_API_KEY blank in local dev to fall back to Mailhog (SMTP) below.
RESEND_API_KEY=
RESEND_FROM=noreply@forethread.local
# Resend webhook signing secret (whsec_…) for the delivery-event receiver
# (POST /v1/webhooks/resend, FOR-213). When set, incoming webhooks must carry a
# valid Svix signature. Leave blank in local dev to accept unsigned calls.
RESEND_WEBHOOK_SECRET=
# Retry tuning for transient Resend failures (rate limits / upstream blips). The
# default ~2 req/s Resend limit can drop sends when an RFQ goes to several
# vendors at once, so failed sends are retried with exponential backoff
# (RESEND_RETRY_BASE_MS, doubling each retry) up to RESEND_MAX_RETRIES times.
RESEND_MAX_RETRIES=3
RESEND_RETRY_BASE_MS=500

# ─── Email / SMTP (fallback) ──────────────────────────────────────────────────
# Used only when RESEND_API_KEY is empty. For local development, use Mailhog
# (docker-compose.dev.yml).
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@forethread.local

# ─── S3 / Object Storage ──────────────────────────────────────────────────────
# For local development, use MinIO (docker-compose.dev.yml)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=forethread-dev
S3_REGION=ap-southeast-2
S3_FORCE_PATH_STYLE=true

# ─── Observability ────────────────────────────────────────────────────────────
# Leave empty for local development
SENTRY_DSN=
LOG_LEVEL=debug

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5179

# ─── Rate Limiting ────────────────────────────────────────────────────────────
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100

# ─── Google Places API ───────────────────────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials
GOOGLE_PLACES_API_KEY=

# ─── Gemini API (document intelligence) ──────────────────────────────────────
# Google AI Studio → Get API key (https://aistudio.google.com/app/apikey)
# Used by the document intelligence pipeline (BOM/invoice extraction)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_MS=60000
# Gemini 2.5 "thinking" budget. 0 disables it (fastest, best for deterministic
# document extraction); -1 = dynamic (model decides); positive = token cap.
GEMINI_THINKING_BUDGET=0
