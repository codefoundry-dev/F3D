# =============================================================================
# Forethread Backend — Environment Variables
# Copy to .env and fill in all required values before running the application.
# =============================================================================

# ─── Application ──────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3001

# ─── Frontend App URLs (per role) ────────────────────────────────────────────
# Used to build email links (reset password, invitation) pointing to the correct app
SUPER_ADMIN_APP_URL=http://localhost:3001
COMPANY_ADMIN_APP_URL=http://localhost:3002
VENDOR_APP_URL=http://localhost:3003
FINANCIAL_OFFICER_APP_URL=http://localhost:3004
PROCUREMENT_OFFICER_APP_URL=http://localhost:3005
WAREHOUSE_OFFICER_APP_URL=http://localhost:3006

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://forethread:forethread@localhost:5432/forethread_dev
# Connection pool (optional — Prisma defaults shown)
DATABASE_CONNECTION_LIMIT=10
DATABASE_POOL_TIMEOUT=10

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT Authentication ───────────────────────────────────────────────────────
# Minimum 32 characters for security — use: openssl rand -hex 32
JWT_ACCESS_SECRET=your-local-dev-access-secret-min-32-chars-replace-this
JWT_REFRESH_SECRET=your-local-dev-refresh-secret-min-32-chars-replace-this
JWT_ACCESS_EXPIRES_IN=4h
JWT_REFRESH_EXPIRES_IN=7d

# ─── Email / SMTP ─────────────────────────────────────────────────────────────
# For local development, use Mailhog (docker-compose.dev.yml)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@forethread.local

# ─── S3 / Object Storage ──────────────────────────────────────────────────────
# For local development, use MinIO (docker-compose.dev.yml)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=forethread-dev
S3_REGION=ap-southeast-2
S3_FORCE_PATH_STYLE=true

# ─── Observability ────────────────────────────────────────────────────────────
# Leave empty for local development
SENTRY_DSN=
LOG_LEVEL=debug

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:3004,http://localhost:3005,http://localhost:3006

# ─── Rate Limiting ────────────────────────────────────────────────────────────
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100

# ─── Google Places API ───────────────────────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials
GOOGLE_PLACES_API_KEY=
