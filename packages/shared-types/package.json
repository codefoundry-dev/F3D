{
  "name": "@forethread/shared-types",
  "version": "0.0.0",
  "private": true,
  "description": "Shared DTOs, enums, and Zod schemas for the Forethread platform",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./client": "./src/client.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/mirror-dist-to-src.cjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts --max-warnings 0",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@nestjs/swagger": "^7.4.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@forethread/config": "workspace:*",
    "@forethread/eslint-config": "workspace:*",
    "typescript": "^5.5.4"
  }
}
