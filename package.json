{
  "name": "forethread",
  "private": true,
  "version": "0.0.0",
  "description": "Forethread — B2B Procurement Management Platform (monorepo)",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test --concurrency=2",
    "test:coverage": "turbo test:coverage --concurrency=2",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\" --ignore-path .prettierignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\" --ignore-path .prettierignore",
    "clean": "turbo clean && find . -name 'node_modules' -type d -prune -not -path '*/.git/*' | xargs rm -rf",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@playwright/test": "^1.58.2",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.3.0",
    "turbo": "^2.3.0"
  },
  "pnpm": {
    "overrides": {},
    "patchedDependencies": {}
  }
}
